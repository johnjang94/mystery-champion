# Required for game logic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Required for voice (TTS)
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Required for 2D photos (https://unsplash.com/oauth/applications)
UNSPLASH_ACCESS_KEY=

# Vercel KV (Upstash Redis under the hood). Provided automatically by `vercel link`+`vercel env pull`.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Pusher Channels (sign up at pusher.com -> Channels app -> App Keys)
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us2
